<?php
session_start();
include_once 'db_connect.php';

// ---------------------------------------------------------
// 1. KIOSK MODE & LOGIC
// ---------------------------------------------------------
if (isset($_GET['mode']) && $_GET['mode'] == 'kiosk') { $_SESSION['kiosk_mode'] = true; }
if (isset($_GET['mode']) && $_GET['mode'] == 'web') { $_SESSION['kiosk_mode'] = false; }
$is_kiosk = isset($_SESSION['kiosk_mode']) && $_SESSION['kiosk_mode'];

// ---------------------------------------------------------
// 2. HELPER FUNCTION (ITO ANG NAG-AAAYOS NG CATEGORY)
// ---------------------------------------------------------
function getSimpleCategory($dbName) {
    $n = strtolower($dbName);
    if (strpos($n, 'adult') !== false) return 'adult';
    if (strpos($n, 'child') !== false) return 'child';
    if (strpos($n, 'infant') !== false) return 'infant';
    return 'addon';
}

// ---------------------------------------------------------
// 3. DEFAULT SELECTION LOGIC
// ---------------------------------------------------------
$preselect_id = $_GET['preselect'] ?? 'DP-RES';

$main_products = [];
$addon_tickets = [];
$sidebar_addons = [];
$page_title = "Book Your Visit";
$main_ticket_image = "Images/placeholder.webp"; 
$main_ticket_description = "Your ultimate waterpark experience starts here!";
$is_preselect = false;

// ---------------------------------------------------------
// 4. DATA FETCHING
// ---------------------------------------------------------
function getProductVariations($pdo, $product_id) {
    $stmt = $pdo->prepare("SELECT * FROM ticket_types WHERE product_id = ? ORDER BY price DESC");
    $stmt->execute([$product_id]);
    return $stmt->fetchAll(PDO::FETCH_ASSOC);
}

// Check if the ID exists
$check_stmt = $pdo->prepare("SELECT COUNT(*) FROM products WHERE product_id = ? AND is_active = 1");
$check_stmt->execute([$preselect_id]);

if ($check_stmt->fetchColumn() > 0) {
    $is_preselect = true;
    
    // Fetch Category Info
    $stmt_cat = $pdo->prepare("
        SELECT p.product_id, p.name, p.price, p.category_id, pc.name as cat_name, pc.description as cat_desc, p.image_url 
        FROM products p 
        LEFT JOIN product_categories pc ON p.category_id = pc.category_id 
        WHERE p.product_id = ? AND p.is_active = 1
    ");
    $stmt_cat->execute([$preselect_id]);
    $details = $stmt_cat->fetch(PDO::FETCH_ASSOC);

    if ($details) {
        $page_title = $details['name']; 
        $main_ticket_description = $details['cat_desc'] ?? $main_ticket_description;
        $main_ticket_image = $details['image_url'] ?? $main_ticket_image;
        
        $details['variations'] = getProductVariations($pdo, $details['product_id']);
        $main_products[] = $details;

        // Fetch Meal Bundles
        if ($details['cat_name'] != 'Meal Bundles') {
            $stmt_addons = $pdo->query("SELECT p.* FROM products p JOIN product_categories pc ON p.category_id = pc.category_id WHERE pc.name = 'Meal Bundles' AND p.is_active = 1");
            $raw_addons = $stmt_addons->fetchAll(PDO::FETCH_ASSOC);
            foreach($raw_addons as $ad) {
                $ad['variations'] = getProductVariations($pdo, $ad['product_id']);
                $addon_tickets[] = $ad;
            }
        }
    }
} else {
    // Fallback logic
    $stmt = $pdo->query("SELECT * FROM products WHERE category_id = 1 AND is_active = 1 ORDER BY price ASC LIMIT 1");
    $fallback = $stmt->fetch(PDO::FETCH_ASSOC);
    if($fallback) {
        $fallback['variations'] = getProductVariations($pdo, $fallback['product_id']);
        $main_products[] = $fallback;
        $page_title = $fallback['name'];
        $main_ticket_image = $fallback['image_url'];
    }
}

// Fetch Sidebar Add-ons start//
//$stmt_sidebar = $pdo->query("SELECT * FROM products WHERE category_id = 6 AND is_active = 1");
//$sidebar_addons = $stmt_sidebar->fetchAll(PDO::FETCH_ASSOC);
// Fetch Sidebar Add-ons end//

// Fetch Sidebar Add-ons
// Temporary hidden Add Ons (lagay dito ang product_id ng gusto mong itago)
$hidden_sidebar_addon_ids = ['ADD1', 'ADD2', 'ADD3', 'ADD4', 'ADD5']; // example only

if (!empty($hidden_sidebar_addon_ids)) {
    $placeholders = implode(',', array_fill(0, count($hidden_sidebar_addon_ids), '?'));
    $sql = "SELECT * 
            FROM products 
            WHERE category_id = 6 
              AND is_active = 1
              AND product_id NOT IN ($placeholders)";
    $stmt_sidebar = $pdo->prepare($sql);
    $stmt_sidebar->execute($hidden_sidebar_addon_ids);
} else {
    $stmt_sidebar = $pdo->query("SELECT * FROM products WHERE category_id = 6 AND is_active = 1");
}

$sidebar_addons = $stmt_sidebar->fetchAll(PDO::FETCH_ASSOC);

// ---------------------------------------------------------
// 5. PREPARE JSON FOR JS
// ---------------------------------------------------------
$tickets_json = [];
$all_items = array_merge($main_products, $addon_tickets, $sidebar_addons);

foreach ($all_items as $item) {
    if (!empty($item['variations'])) {
        foreach ($item['variations'] as $v) {
            $tickets_json['type_' . $v['type_id']] = ['price' => (float)$v['price']];
        }
    } else {
        $tickets_json['prod_' . $item['product_id']] = ['price' => (float)$item['price']];
    }
}

function getIconForProduct($name) {
    $n = strtolower($name);
    if (strpos($n, 'parking') !== false) return 'fa-parking';
    if (strpos($n, 'zipline') !== false) return 'fa-wind';
    if (strpos($n, 'locker') !== false) return 'fa-lock';
    if (strpos($n, 'bridge') !== false) return 'fa-bridge-water';
    if (strpos($n, 'photo') !== false) return 'fa-camera';
    if (strpos($n, 'meal') !== false) return 'fa-utensils';
    return 'fa-ticket-alt'; 
}

// ---------------------------------------------------------
// 6. CALENDAR CONTROLS + BOOKING COUNTS
// ---------------------------------------------------------
$calendar_date_controls = [];
$calendar_month_controls = [];
$calendar_booking_counts = [];

/*
|--------------------------------------------------------------------------
| MONTH CONTROLS
|--------------------------------------------------------------------------
| Default behavior:
| - no row = enabled
| - row exists with is_enabled=0 => whole month disabled
| - row exists with is_enabled=1 => whole month explicitly enabled
*/
try {
    $stmt = $pdo->query("
        SELECT month_key, is_enabled, notes
        FROM calendar_month_controls
    ");
    while ($row = $stmt->fetch(PDO::FETCH_ASSOC)) {
        $calendar_month_controls[$row['month_key']] = [
            'is_enabled' => (int)$row['is_enabled'],
            'notes'      => $row['notes'] ?? ''
        ];
    }
} catch (Throwable $e) {
    // Safe fallback if table does not exist yet
    $calendar_month_controls = [];
}

/*
|--------------------------------------------------------------------------
| DATE CONTROLS
|--------------------------------------------------------------------------
| Specific date has higher priority than month rule.
*/
try {
    $stmt = $pdo->query("
        SELECT control_date, is_enabled, max_bookings, notes
        FROM calendar_date_controls
    ");
    while ($row = $stmt->fetch(PDO::FETCH_ASSOC)) {
        $calendar_date_controls[$row['control_date']] = [
            'is_enabled'   => (int)$row['is_enabled'],
            'max_bookings' => $row['max_bookings'] !== null ? (int)$row['max_bookings'] : null,
            'notes'        => $row['notes'] ?? ''
        ];
    }
} catch (Throwable $e) {
    // Safe fallback if table does not exist yet
    $calendar_date_controls = [];
}

/*
|--------------------------------------------------------------------------
| CURRENT BOOKING COUNTS PER DATE
|--------------------------------------------------------------------------
| This counts number of booking records per day.
| If gusto mong count ng total guests/tickets instead of booking rows,
| palitan mo ang COUNT(*) ng tamang SUM(column_name).
*/
try {
    $stmt = $pdo->query("
        SELECT DATE(booking_date) AS booking_day, COUNT(*) AS total_bookings
        FROM bookings
        WHERE DATE(booking_date) >= CURDATE()
          AND status IN ('pending', 'paid', 'confirmed')
        GROUP BY DATE(booking_date)
    ");
    while ($row = $stmt->fetch(PDO::FETCH_ASSOC)) {
        $calendar_booking_counts[$row['booking_day']] = (int)$row['total_bookings'];
    }
} catch (Throwable $e) {
    // Safe fallback if query fails or columns differ
    $calendar_booking_counts = [];
}
?>

