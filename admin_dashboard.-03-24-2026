                            }
                        }
                    }
                    // Check member pass visits
                    if (!$isRedeemed && !empty($txn_pass_visits)) {
                        $isRedeemed = true;
                        if ($redeemedBy == '-' || $redeemedBy == '') $redeemedBy = 'System (Pass Scan)';
                        if ($redeemedAt == '-' || $redeemedAt == '') $redeemedAt = $txn_pass_visits[0]['visit_date'] ?? '-';
